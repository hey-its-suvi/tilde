{
  "name": "tilde",
  "version": "0.3.12",
  "description": "A declarative geometric programming language",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vitepress dev docs --port 5173\" \"vite --port 5174\"",
    "playground": "vite --port 5174",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev docs --port 5173",
    "docs:build": "vitepress build docs",
    "test": "vitest"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "mermaid": "^11.14.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "codemirror": "^6.0.2"
  }
}
